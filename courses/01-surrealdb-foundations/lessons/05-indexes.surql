-- Lesson 05: Indexes and Performance
-- ─────────────────────────────────────────────────────────────────────────────

-- ─── Standard indexes ────────────────────────────────────────────────────────

-- Basic index (speeds up WHERE filters)
DEFINE INDEX idx_agent_tenant   ON TABLE agent COLUMNS tenant_id;
DEFINE INDEX idx_agent_status   ON TABLE agent COLUMNS status;
DEFINE INDEX idx_agent_created  ON TABLE agent COLUMNS created_at;

-- Compound index
DEFINE INDEX idx_agent_tenant_status ON TABLE agent COLUMNS tenant_id, status;

-- Unique index (enforces uniqueness at DB level)
DEFINE INDEX idx_agent_id_unique ON TABLE agent COLUMNS agent_id UNIQUE;

-- Try inserting a duplicate agent_id — this will fail
-- CREATE agent SET agent_id = 'orch', tenant_id = 'acme2', name = 'Dup';
-- Error: Database index `idx_agent_id_unique` already contains 'orch'

-- ─── Full-text search index ───────────────────────────────────────────────────

DEFINE TABLE knowledge_item SCHEMAFULL;
DEFINE FIELD content    ON TABLE knowledge_item TYPE string;
DEFINE FIELD title      ON TABLE knowledge_item TYPE string;
DEFINE FIELD tags       ON TABLE knowledge_item TYPE array DEFAULT [];

-- Define a search analyzer (tokenizer + filters)
DEFINE ANALYZER content_analyzer
    TOKENIZERS blank, class
    FILTERS ascii, snowball(english);

-- Create full-text search index
DEFINE INDEX idx_knowledge_content ON TABLE knowledge_item
    FIELDS content
    SEARCH ANALYZER content_analyzer BM25;

DEFINE INDEX idx_knowledge_title ON TABLE knowledge_item
    FIELDS title
    SEARCH ANALYZER content_analyzer BM25;

-- Insert some knowledge
CREATE knowledge_item SET
    title = 'SurrealDB agent memory patterns',
    content = 'SurrealDB supports episodic, semantic, procedural, and working memory for AI agents using vector search and full-text search.';

CREATE knowledge_item SET
    title = 'Schema.org JSON-LD as knowledge graph',
    content = 'Using Schema.org types as the data model for a knowledge graph enables semantic interoperability and semantic web compatibility.';

-- Full-text search query
SELECT *, search::score(1) AS score
FROM knowledge_item
WHERE title @1@ 'agent memory'
ORDER BY score DESC;

-- ─── Vector search index ─────────────────────────────────────────────────────

DEFINE TABLE embedding_store SCHEMAFULL;
DEFINE FIELD content    ON TABLE embedding_store TYPE string;
DEFINE FIELD embedding  ON TABLE embedding_store TYPE array;

-- MTREE vector index (cosine similarity)
DEFINE INDEX idx_embedding_vector ON TABLE embedding_store
    FIELDS embedding
    MTREE DIMENSION 4;  -- use 1536 for OpenAI ada-002, 768 for local models

-- Insert with a small test embedding (normally generated by a model)
CREATE embedding_store SET
    content = 'Agent memory with vector search',
    embedding = [0.1, 0.9, 0.3, 0.7];

CREATE embedding_store SET
    content = 'SurrealDB live queries for real-time state',
    embedding = [0.8, 0.2, 0.6, 0.1];

-- Vector similarity search (find most similar to query vector)
SELECT content,
    vector::similarity::cosine(embedding, [0.15, 0.85, 0.25, 0.65]) AS similarity
FROM embedding_store
ORDER BY similarity DESC
LIMIT 5;

-- TAKEAWAY: SurrealDB has three index types in one system:
-- 1. Standard (BTree) — for WHERE filters
-- 2. Full-text search (BM25) — for keyword search
-- 3. Vector (MTREE) — for semantic similarity search
-- No Elasticsearch, Pinecone, or separate vector DB needed.
